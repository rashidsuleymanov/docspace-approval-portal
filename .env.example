DOCSPACE_BASE_URL=https://your-docspace.example.com
DOCSPACE_AUTH_TOKEN=YOUR_DOCSPACE_ADMIN_TOKEN

# Recommended (client uses this to load DocSpace SDK)
VITE_DOCSPACE_URL=https://your-docspace.example.com

# Demo stand mode (set to true to enable the demo stand)
DEMO_MODE=true

# Demo session settings
DEMO_EMAIL_DOMAIN=demo.local
DEMO_SESSION_TTL_MINUTES=45
DEMO_SESSION_IDLE_MINUTES=20
DEMO_SESSION_JANITOR_INTERVAL_SECONDS=60
# DEMO_SESSION_STORE_PATH=server/.data/demo-sessions.json

# Optional: pre-copy this template file into each demo project room on start
# DOCSPACE_DEMO_TEMPLATE_FILE_ID=

# Optional (Forms workflow)
DOCSPACE_FORMS_ROOM_TITLE=Forms Room
DOCSPACE_FORMS_ROOM_TITLE_FALLBACKS=Medical Room,Medical Forms
DOCSPACE_FORMS_TEMPLATES_FOLDER_TITLE=Templates

# Optional (client idle/hidden timeouts in milliseconds)
# VITE_DEMO_IDLE_TIMEOUT_MS=300000
# VITE_DEMO_HIDDEN_TIMEOUT_MS=30000

# Optional (local dev only — do NOT set to true in production)
# ENABLE_DEBUG_API=true

# Optional (persistence — set to off to disable)
# DOCSPACE_APPROVAL_PORTAL_STORE_PATH=server/.data/store.json
